# Copy to inventory.ini and edit for your environment.
# Hostnames resolve via your router's DHCP-registered DNS
# (e.g. Ubiquiti serves k3s-gpu.localdomain once the node announces its hostname).
#
# Node roles:
#   control - k3s server (control plane). Stable, always-on worker.
#   workers - additional k3s agents. Stable, always-on.
#   gpu     - k3s agent with NVIDIA GPU. May reboot for driver updates.
#
# Add nodes as you bring them online. `cluster_manager.py prep-node <host>`
# targets a single host; `cluster_manager.py bootstrap` targets the whole file.

[control]
k3s-control.localdomain

[workers]
k3s-worker.localdomain

[gpu]
k3s-gpu.localdomain

[agents:children]
workers
gpu

[all:vars]
ansible_user=ubuntu
ansible_python_interpreter=/usr/bin/python3
