# Managed by `cluster_manager.py prep-node`. You can also edit manually.
#
# Node roles:
#   control - k3s server (control plane). Stable, always-on.
#   workers - additional k3s agents. Stable, always-on.
#   gpu     - k3s agent with NVIDIA GPU. May reboot for driver updates.
#
# Example after prepping three nodes:
#
#   [control]
#   k3s-control ansible_host=192.168.1.10
#
#   [workers]
#   k3s-worker ansible_host=192.168.1.11
#
#   [gpu]
#   k3s-gpu ansible_host=192.168.1.12
#
#   [agents:children]
#   workers
#   gpu
#
#   [all:vars]
#   ansible_user=ubuntu
#   ansible_python_interpreter=/usr/bin/python3

[control]

[workers]

[gpu]

[agents:children]
workers
gpu

[all:vars]
ansible_user=ubuntu
ansible_python_interpreter=/usr/bin/python3
